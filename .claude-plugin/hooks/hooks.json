{
  "description": "Auto-update Zellij tab status based on Claude Code lifecycle events.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "zellij pipe --plugin smart-tabs --name status -- \"$ZELLIJ_PANE_ID busy\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "zellij pipe --plugin smart-tabs --name status -- \"$ZELLIJ_PANE_ID busy\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "zellij pipe --plugin smart-tabs --name status -- \"$ZELLIJ_PANE_ID busy\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "zellij pipe --plugin smart-tabs --name status -- \"$ZELLIJ_PANE_ID help\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "zellij pipe --plugin smart-tabs --name status -- \"$ZELLIJ_PANE_ID ready\""
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "zellij pipe --plugin smart-tabs --name status -- \"$ZELLIJ_PANE_ID ready\""
          }
        ]
      }
    ]
  }
}
